rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasAdminClaim() {
      return isSignedIn() &&
        (request.auth.token.admin == true || request.auth.token.role == 'admin');
    }

    function isAdmin() {
      return hasAdminClaim();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userCreateAllowedKeys() {
      return [
        'id',
        'email',
        'name',
        'displayName',
        'phone',
        'phoneNumber',
        'birth',
        'birthDate',
        'gender',
        'termsAgree',
        'privacyAgree',
        'marketingAgree',
        'marketingAgreed',
        'address',
        'addresses',
        'profileImage',
        'preferences',
        'createdAt',
        'updatedAt'
      ];
    }

    function userUpdateAllowedKeys() {
      return [
        'email',
        'name',
        'displayName',
        'phone',
        'phoneNumber',
        'birth',
        'birthDate',
        'gender',
        'marketingAgree',
        'marketingAgreed',
        'address',
        'addresses',
        'profileImage',
        'preferences',
        'updatedAt'
      ];
    }

    function isValidSelfUserCreate(userId) {
      return isOwner(userId) &&
        request.resource.data.keys().hasOnly(userCreateAllowedKeys()) &&
        (!request.resource.data.keys().hasAny(['id']) ||
          request.resource.data.id == userId);
    }

    function isValidSelfUserUpdate(userId) {
      return isOwner(userId) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(userUpdateAllowedKeys());
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();

      match /products/{productId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow create: if isValidSelfUserCreate(userId) || isAdmin();
      allow read: if isOwner(userId) || isAdmin();
      allow update: if isValidSelfUserUpdate(userId) || isAdmin();
      allow delete: if isAdmin();

      match /pointHistory/{historyId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }

      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /recentProducts/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /carts/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /orders/{orderId} {
      allow create: if false;
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /user_coupons/{userCouponId} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /userRecentProducts/{docId} {
      allow create: if isSignedIn() &&
        (request.resource.data.userId == request.auth.uid || isAdmin());
      allow read, update, delete: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /userWishlist/{docId} {
      allow create: if isSignedIn() &&
        (request.resource.data.userId == request.auth.uid || isAdmin());
      allow read, update, delete: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /qna/{qnaId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid) ||
        (resource.data.isSecret != true);
      allow update, delete: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /inquiries/{inquiryId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /migrationRuns/{runId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
