{
  "name": "hebimall",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit --pretty false --incremental false -p tsconfig.json",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run functions:build",
    "verify": "npm run typecheck && npm run lint -- --max-warnings=0 && npm run test && npm run functions:build && npm run build",
    "seed": "npm run seed:all",
    "seed:all": "node scripts/seed-all.js",
    "seed:categories": "node scripts/seed-categories-fixed.js",
    "seed:products": "node scripts/seed-products-fixed.js",
    "seed:users": "node scripts/seed-users.js",
    "seed:coupons": "node scripts/seed-coupons.js",
    "seed:content": "node scripts/seed-static-content.js",
    "deploy:firebase": "npm run verify && node scripts/copy-next-to-functions.js && firebase deploy",
    "deploy:prep": "npm run build && node scripts/copy-next-to-functions.js",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:hosting": "firebase deploy --only hosting",
    "setup:env": "node scripts/setup-firebase-secrets.js",
    "functions:build": "npm run sync:chat-responses && cd functions && npm run build",
    "sync:chat-responses": "node scripts/sync-chat-responses.js",
    "functions:deploy": "npm run functions:build && firebase deploy --only functions",
    "migrate:firestore:analyze": "node scripts/firestore-products-v2-migration.js analyze",
    "migrate:firestore:products:dry-run": "node scripts/firestore-products-v2-migration.js migrate",
    "migrate:firestore:products:execute": "node scripts/firestore-products-v2-migration.js migrate --execute",
    "migrate:firestore:validate": "node scripts/firestore-products-v2-migration.js validate",
    "firestore:ai-summary": "node scripts/firestore-ai-summary.js",
    "cleanup:legacy-products:backup": "node scripts/firestore-legacy-products-cleanup.js backup",
    "cleanup:legacy-products:dry-run": "node scripts/firestore-legacy-products-cleanup.js dry-run",
    "cleanup:legacy-products:execute": "node scripts/firestore-legacy-products-cleanup.js execute",
    "migrate:product-images:analyze": "node scripts/product-image-webp-migration.js analyze",
    "migrate:product-images:dry-run": "node scripts/product-image-webp-migration.js migrate",
    "migrate:product-images:execute": "node scripts/product-image-webp-migration.js migrate --execute",
    "migrate:product-images:delete-originals": "node scripts/product-image-webp-migration.js delete-originals --latest-log",
    "migrate:product-images:validate": "node scripts/product-image-webp-migration.js validate",
    "migrate:content-images:analyze": "node scripts/content-image-webp-migration.js analyze",
    "migrate:content-images:dry-run": "node scripts/content-image-webp-migration.js migrate",
    "migrate:content-images:execute": "node scripts/content-image-webp-migration.js migrate --execute",
    "migrate:content-images:delete-originals": "node scripts/content-image-webp-migration.js delete-originals",
    "migrate:content-images:validate": "node scripts/content-image-webp-migration.js validate",
    "test": "jest --runInBand",
    "test:functions": "jest --runInBand functions/__tests__",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.84.1",
    "dotenv": "^17.2.1",
    "firebase": "^12.0.0",
    "next": "^15.5.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.7",
    "firebase-admin": "^13.6.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5"
  }
}
